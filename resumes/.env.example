# Copy to .env and fill in your API key
# Get your key from: https://rxresu.me → Settings → API Keys
RX_RESUME_API_KEY=your-api-key-here

# --- CV application tracker (Google Sheets sync) ---
# Sheet ID from URL: docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Applications
# Path (relative to repo root) to service-account JSON key
GOOGLE_CREDS_PATH=_creeds/your-service-account.json
